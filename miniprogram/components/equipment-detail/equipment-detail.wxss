.tt-footer-wrap {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
  margin-bottom: 32rpx;
}

.tt-bot-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #dcd3c4;
}

.tt-bot-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
  background: #cda86a;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
  -webkit-mask-size: contain;
  mask-repeat: no-repeat;
