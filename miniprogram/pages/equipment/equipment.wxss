/* ── modal / tooltip ── */
.modal-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.8);
  z-index: 99;
}

.modal-card {
  position: relative;
  width: 660rpx;
  height: 84vh;
  max-height: 84vh;
  border-radius: 40rpx;
  overflow: hidden;
  background: #141018;
  border: 2rpx solid rgba(255, 187, 18, 0.4);
  box-shadow:
    0 16rpx 48rpx rgba(0, 0, 0, 0.6),
    0 0 20rpx rgba(255, 187, 18, 0.1);
  display: flex;
  flex-direction: column;
}

.modal-close {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  z-index: 10;
  width: 52rpx;
  height: 52rpx;
  border-radius: 99rpx;
  border: 2rpx solid rgba(255, 187, 18, 0.5);
  color: #ffbb12;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0;
  line-height: 0;
  font-weight: 300;
  padding: 0;
  background: rgba(255, 187, 18, 0.05);
}

.modal-close::before,
.modal-close::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #ffbb12;
  transform-origin: center;
}

.modal-close::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.modal-close::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

