.index-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 24rpx;
}

.app-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--theme);
  letter-spacing: 4rpx;
  margin-bottom: 80rpx;
}

.class-row {
  display: flex;
  justify-content: center;
  gap: 36rpx;
  margin-bottom: 48rpx;
}

.class-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.class-cell:active .class-emblem {
  transform: scale(0.9);
  opacity: 0.85;
}

.class-emblem {
  width: 120rpx;
  height: 120rpx;
  transition: transform 0.15s, opacity 0.15s;
}

.class-label {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}
