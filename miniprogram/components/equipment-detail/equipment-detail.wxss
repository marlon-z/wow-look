.tt-ornament {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 40rpx;
  margin-bottom: 10rpx;
}

.orn-line {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 187, 18, 0.4), transparent);
}

.orn-dot {
  width: 8rpx;
  height: 8rpx;
  background: #ffbb12;
  transform: rotate(45deg);
}
