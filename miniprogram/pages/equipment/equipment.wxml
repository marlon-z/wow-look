<view class="page-shell equipment-page">
  <view class="top-card">
    <view class="top-row">
      <text class="back-link" bindtap="onBackTap">返回</text>
      <view class="pill">{{classMeta.armorTypeName}}</view>
    </view>
    <text class="page-title">{{className}}</text>
    <text class="page-copy">按专精、副属性、部位和关键词筛选当前赛季装备。</text>
  </view>

  <view class="filter-panel">
    <view class="filter-head">
      <view>
        <text class="result-count">{{resultCount}} 件结果</text>
        <text class="result-copy">全部结果来自当前赛季插件导出</text>
      </view>
      <view class="reset-chip" bindtap="resetFilters">重置</view>
    </view>

    <view class="search-box">
      <input
        class="search-input"
        placeholder="搜索装备名、副本名或首领名"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onKeywordInput"
      />
    </view>

    <view class="filter-block">
      <text class="filter-label">专精</text>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{specs}}"
            wx:key="id"
            class="filter-tag {{selectedSpec === item.id ? 'active' : ''}}"
            bindtap="onSpecTap"
            data-id="{{item.id}}"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="filter-block">
      <text class="filter-label">副属性</text>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{stats}}"
            wx:key="type"
            class="filter-tag {{item.selected ? 'active' : ''}}"
            bindtap="onStatTap"
            data-type="{{item.type}}"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="filter-block">
      <text class="filter-label">结果视图</text>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{viewModes}}"
            wx:key="type"
            class="filter-tag {{selectedViewMode === item.type ? 'active' : ''}}"
            bindtap="onViewModeTap"
            data-type="{{item.type}}"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="filter-block">
      <text class="filter-label">来源</text>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{sourceTypes}}"
            wx:key="type"
            class="filter-tag {{selectedSourceType === item.type ? 'active' : ''}}"
            bindtap="onSourceTypeTap"
            data-type="{{item.type}}"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="filter-block">
      <text class="filter-label">部位</text>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{slots}}"
            wx:key="type"
            class="filter-tag compact {{selectedSlot === item.type ? 'active' : ''}}"
            bindtap="onSlotTap"
            data-type="{{item.type}}"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="filter-block">
      <text class="filter-label">副本</text>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{instanceOptions}}"
            wx:key="id"
            wx:if="{{selectedSourceType === 'all' || item.type === selectedSourceType}}"
            class="filter-tag compact {{selectedInstanceId === item.id ? 'active' : ''}}"
            bindtap="onInstanceTap"
            data-id="{{item.id}}"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <scroll-view scroll-y class="result-scroll" enhanced show-scrollbar="{{false}}">
    <block wx:if="{{isLoading}}">
      <view class="empty-card">
        <text class="empty-title">数据加载中</text>
      </view>
    </block>

    <block wx:elif="{{groupedItems.length === 0}}">
      <view class="empty-card">
        <text class="empty-title">{{emptyMessage}}</text>
      </view>
    </block>

    <block wx:else>
      <block wx:for="{{groupedItems}}" wx:key="slotType">
        <view class="slot-section">
          <block wx:if="{{selectedViewMode === 'slot'}}">
            <view class="slot-head">
              <text class="slot-title">{{item.slotName}}</text>
              <text class="slot-count">{{item.items.length}} 件</text>
            </view>
          </block>

          <block wx:else>
            <view class="slot-head source-head">
              <view>
                <text class="slot-title">{{item.title}}</text>
                <text class="source-subtitle">{{item.subtitle}}<block wx:if="{{item.difficultyName}}"> · {{item.difficultyName}}</block></text>
              </view>
              <text class="slot-count">{{item.items.length}} 件</text>
            </view>
          </block>

          <view
            wx:for="{{item.items}}"
            wx:key="id"
            wx:for-item="equip"
            class="item-card"
            bindtap="onItemTap"
            data-item-id="{{equip.id}}"
          >
            <view class="item-icon">
              <image wx:if="{{equip.iconAsset}}" class="item-icon-image" mode="aspectFill" src="{{equip.iconAsset}}" />
              <text wx:else class="item-icon-text">{{equip.iconText}}</text>
            </view>

            <view class="item-main">
              <text class="item-name epic-text">{{equip.name}}</text>
              <text class="item-meta">{{equip.metaLine}}</text>
              <text class="item-stat">{{equip.statLine}}</text>
              <text class="item-source">{{equip.instanceName}} · {{equip.encounterName}}</text>
            </view>
          </view>
        </view>
      </block>
    </block>
  </scroll-view>

  <view wx:if="{{showModal}}" class="modal-mask" bindtap="closeModal">
    <view class="modal-card" catchtap="preventClose">
      <view class="modal-close" bindtap="closeModal">×</view>

      <view class="modal-header">
        <view class="modal-icon">
          <image wx:if="{{selectedItem.iconAsset}}" class="modal-icon-image" mode="aspectFill" src="{{selectedItem.iconAsset}}" />
          <text wx:else class="modal-icon-text">{{selectedItem.iconText}}</text>
        </view>
        <view class="modal-head-copy">
          <text class="modal-name epic-text">{{selectedItem.name}}</text>
          <text class="modal-meta">{{selectedItem.metaLine}}</text>
          <text class="modal-specs">可用专精：{{selectedItem.specText}}</text>
        </view>
      </view>

      <scroll-view scroll-y class="modal-body" enhanced show-scrollbar="{{false}}">
        <view class="tooltip-quality-bar"></view>
        <text class="detail-line level-line">物品等级{{selectedItem.ilvl}}</text>
        <text wx:if="{{selectedItem.upgradeTrack}}" class="detail-line level-line">升级：{{selectedItem.upgradeTrack}}</text>
        <text class="detail-line">{{selectedItem.slotName}}<block wx:if="{{selectedItem.itemSubType}}"> · {{selectedItem.itemSubType}}</block></text>
        <text wx:if="{{selectedItem.tooltipFlags.uniqueEquipped}}" class="detail-line">装备唯一</text>
        <text wx:if="{{selectedItem.tooltipFlags.prismaticSocket}}" class="detail-line">棱彩插槽</text>

        <block wx:for="{{selectedItem.whiteLines}}" wx:key="*this">
          <text class="detail-line">{{item}}</text>
        </block>

        <block wx:for="{{selectedItem.stats.primaryStats}}" wx:key="type">
          <text class="detail-line">+{{item.value}} {{item.name}}</text>
        </block>

        <text wx:if="{{selectedItem.stats.stamina}}" class="detail-line">+{{selectedItem.stats.stamina.value}} {{selectedItem.stats.stamina.name}}</text>

        <view wx:if="{{selectedItem.secondaryStats && selectedItem.secondaryStats.length}}" class="stat-bar-list">
          <view wx:for="{{selectedItem.secondaryStats}}" wx:key="type" class="stat-bar-row">
            <view class="stat-bar-head">
              <text class="detail-line green-line">+{{item.value}} {{item.name}}</text>
            </view>
            <view class="stat-bar-track">
              <view class="stat-bar-fill" style="width: {{item.width}};"></view>
            </view>
          </view>
        </view>

        <block wx:for="{{selectedItem.equipEffects}}" wx:key="*this">
          <text class="detail-line green-line">装备：{{item}}</text>
        </block>

        <block wx:for="{{selectedItem.useEffects}}" wx:key="*this">
          <text class="detail-line green-line">使用：{{item}}</text>
        </block>

        <view wx:if="{{selectedItem.tooltipRaw && selectedItem.tooltipRaw.length}}" class="raw-block">
          <text class="raw-title">原始说明</text>
          <block wx:for="{{selectedItem.tooltipRaw}}" wx:key="index">
            <text class="raw-line">{{item}}</text>
          </block>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <text class="footer-line">{{selectedItem.instanceName}}</text>
        <text class="footer-line">{{selectedItem.encounterName}} · {{selectedItem.source.difficultyName}}</text>
        <text class="footer-line muted">图标ID {{selectedItem.icon}} · 装备ID {{selectedItem.id}}</text>
      </view>
    </view>
  </view>
</view>
