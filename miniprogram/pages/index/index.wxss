.index-page {
  padding: 34rpx 28rpx 42rpx;
}

.hero-card {
  padding: 34rpx 30rpx 38rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 0 0, rgba(190, 143, 66, 0.18), rgba(190, 143, 66, 0)),
    linear-gradient(150deg, rgba(31, 24, 20, 0.98), rgba(17, 14, 22, 0.96));
  border: 2rpx solid rgba(190, 143, 66, 0.2);
  box-shadow: 0 24rpx 48rpx rgba(0, 0, 0, 0.28);
}

.hero-tag {
  display: block;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--text-dim);
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 66rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: var(--theme);
}

.hero-copy {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-soft);
}

.hero-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.section-head {
  margin-top: 38rpx;
  margin-bottom: 22rpx;
}

.summary-card {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.summary-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
}

.summary-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-soft);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.section-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-soft);
}

.class-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.class-card {
  padding: 24rpx 16rpx 18rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
    var(--surface);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.class-mark {
  width: 84rpx;
  height: 84rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  font-size: 38rpx;
  font-weight: 700;
}

.class-name {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.class-armor {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-soft);
}

.class-count {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: var(--text-dim);
}
