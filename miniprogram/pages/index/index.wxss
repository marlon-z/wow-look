.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  margin-bottom: 50rpx;
}

.logo-img {
 
  max-width: 95%;
  display: block;
}

/* ── Prompt Section ── */
.prompt-wrap {
  margin-bottom: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.prompt-text {
  font-size: 28rpx;
  color: #dfd4c1;
  font-weight: 500;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.8);
}

.prompt-text::before,
.prompt-text::after {
  content: "—";
  margin: 0 16rpx;
  color: rgba(223, 212, 193, 0.3);
}

/* ── Class Grid ── */
.class-grid-wrap {
  width: 100%;
}

.class-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.class-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 16rpx;
  border-radius: 20rpx;
  background: rgba(13, 10, 18, 0.8);
  border: 1rpx solid rgba(212, 168, 75, 0.25);
  box-shadow:
    0 8rpx 16rpx rgba(0,0,0,0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  transition: transform 0.15s, border-color 0.15s;
}

.class-cell:active {
  transform: scale(0.96);
  border-color: rgba(212, 168, 75, 0.6);
}

.class-emblem {
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 20rpx;
}

.class-label {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-align: center;
}

/* ── Footer ── */
.footer-note {
  margin-top: auto;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.footer-note text {
  font-size: 22rpx;
  color: #4a4439;
  letter-spacing: 1rpx;
}

.footer-ornament {
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid #3c362b;
  transform: rotate(45deg);
}

