.index-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 0 24rpx;
  background:
    radial-gradient(circle at top, rgba(30, 25, 40, 0.4), transparent 50%),
    linear-gradient(180deg, #09080d 0%, #15111b 100%);
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  margin-bottom: 50rpx;
}

.main-title {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.main-title text {
  font-size: 80rpx;
  font-weight: 900;
  color: #d1a153;
  letter-spacing: 12rpx;
  font-family: "Times New Roman", serif;
  text-shadow:
    0 4rpx 12rpx rgba(0, 0, 0, 0.8),
    0 0 40rpx rgba(209, 161, 83, 0.4);
}

.title-ornament {
  width: 40rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #cda86a);
  position: relative;
}

.title-ornament.right {
  background: linear-gradient(-90deg, transparent, #cda86a);
}

.title-ornament::after {
  content: '';
  position: absolute;
  right: -6rpx;
  top: -4rpx;
  width: 12rpx;
  height: 12rpx;
  background: transparent;
  border: 2rpx solid #d1a153;
  transform: rotate(45deg);
}

.title-ornament.right::after {
  right: auto;
  left: -6rpx;
}

.sub-title {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.sub-title text {
  font-size: 28rpx;
  color: #be9047;
  letter-spacing: 4rpx;
}

.sub-ornament {
  width: 30rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(205, 168, 106, 0.6));
  position: relative;
}

.sub-ornament.right {
  background: linear-gradient(-90deg, transparent, rgba(205, 168, 106, 0.6));
}

.sub-ornament::after {
  content: '';
  position: absolute;
  right: -4rpx;
  top: -4rpx;
  width: 8rpx;
  height: 8rpx;
  background: transparent;
  border: 2rpx solid #be9047;
  transform: rotate(45deg);
}

.sub-ornament.right::after {
  right: auto;
  left: -4rpx;
}

/* ── Prompt Section ── */
.prompt-wrap {
  margin-bottom: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.prompt-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.25);
  letter-spacing: 4rpx;
}

.prompt-text::before,
.prompt-text::after {
  content: "—";
  margin: 0 16rpx;
  color: rgba(255, 255, 255, 0.1);
}

/* ── Class Grid ── */
.class-grid-wrap {
  width: 100%;
}

.class-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.class-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 16rpx;
  border-radius: 20rpx;
  background: rgba(13, 10, 18, 0.8);
  border: 1rpx solid rgba(212, 168, 75, 0.25);
  box-shadow:
    0 8rpx 16rpx rgba(0,0,0,0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  transition: transform 0.15s, border-color 0.15s;
}

.class-cell:active {
  transform: scale(0.96);
  border-color: rgba(212, 168, 75, 0.6);
}

.class-emblem {
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 20rpx;
}

.class-label {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-align: center;
}

/* ── Footer ── */
.footer-note {
  margin-top: auto;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.footer-note text {
  font-size: 22rpx;
  color: #4a4439;
  letter-spacing: 1rpx;
}

.footer-ornament {
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid #3c362b;
  transform: rotate(45deg);
}
