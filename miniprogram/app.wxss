page {
  background: #09080d;
  color: #e8e4dc;
  font-family: "PingFang SC", "SF Pro Display", "Helvetica Neue", sans-serif;
  --theme: #d4a84b;
  --theme-dim: #a07a2e;
  --theme-soft: rgba(212, 168, 75, 0.14);
  --theme-glow: rgba(212, 168, 75, 0.06);
  --surface: #111018;
  --surface-raised: #16141e;
  --surface-strong: #1a1824;
  --border: rgba(212, 168, 75, 0.10);
  --border-subtle: rgba(255, 255, 255, 0.05);
  --text-main: #e8e4dc;
  --text-soft: #9e9688;
  --text-dim: #5e574d;
  --epic: #a335ee;
  --rare: #0070dd;
  --green: #1eff00;
  --poor: #9d9d9d;
  box-sizing: border-box;
}

view,
text,
scroll-view {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--border);
  background: var(--theme-glow);
  color: var(--theme);
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

.epic-text {
  color: var(--epic);
}

.muted {
  color: var(--text-dim);
}
