.build-draft-panel {
  max-height: 84vh;
}

.build-share-mini {
  height: 48rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(42, 35, 25, 0.88), rgba(18, 14, 12, 0.92));
  border: 2rpx solid rgba(212, 168, 75, 0.42);
  color: #d8bf82;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 48rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 6rpx 14rpx rgba(0, 0, 0, 0.24);
}

.build-share-mini::after {
  border: 0;
}

.build-import-all {
  color: #d8bf82;
  border-color: rgba(212, 168, 75, 0.42);
}

.build-picked-badge {
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8d8579;
  font-size: 20rpx;
  font-weight: 800;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.04);
}

.build-picked-badge.on {
  color: #ffbb12;
  border-color: rgba(255, 187, 18, 0.38);
  background: rgba(255, 187, 18, 0.1);
}
