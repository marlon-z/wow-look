.tt-extra-col {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  z-index: 2;
}

.tt-extra-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #dcd3c4;
}

.green-text {
  color: #1eff00;
  font-weight: 500;
}

.gold-text {
  color: #e7c46a;
  font-weight: 500;
}

.dim-text {
  color: rgba(220, 211, 196, 0.72);
}

