/* ---- Favorite Entry & Modal (Shared) ---- */
.favorite-entry {
  position: relative;
  height: 56rpx;
  padding: 0 24rpx 0 20rpx;
  border-radius: 56rpx;
  background: linear-gradient(180deg, rgba(34, 28, 42, 0.65), rgba(16, 12, 20, 0.9));
  backdrop-filter: blur(32px);
  -webkit-backdrop-filter: blur(32px);
  border: 1rpx solid rgba(212, 168, 75, 0.5);
  box-shadow: 
    0 10rpx 20rpx rgba(0, 0, 0, 0.7),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15),
    inset 0 -1rpx 0 rgba(212, 168, 75, 0.15),
    inset 0 0 12rpx rgba(212, 168, 75, 0.05);
  display: flex;
  align-items: center;
  gap: 10rpx;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.top-favorite-entry {
  flex-shrink: 0;
  height: 52rpx;
  padding: 0 20rpx 0 18rpx;
  border-radius: 52rpx;
  gap: 8rpx;
}

.top-favorite-entry .favorite-entry-icon {
  width: 24rpx;
  height: 24rpx;
}

.top-favorite-entry .favorite-entry-label {
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.top-favorite-entry .favorite-entry-count {
  font-size: 22rpx;
  padding-left: 12rpx;
}

.favorite-entry::before {
  content: '';
  position: absolute;
  inset: 3rpx;
  border-radius: 56rpx;
  border: 1rpx dashed rgba(212, 168, 75, 0.25);
  pointer-events: none;
}

.favorite-entry:active {
  transform: scale(0.94) translateY(2rpx);
  background: linear-gradient(180deg, rgba(38, 32, 46, 0.8), rgba(20, 16, 24, 0.95));
  border-color: rgba(212, 168, 75, 0.8);
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.8),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.favorite-entry-icon {
  width: 28rpx;
  height: 28rpx;
  filter: drop-shadow(0 0 12rpx rgba(255, 187, 18, 0.6));
}

.favorite-entry-label {
  font-size: 24rpx;
  font-weight: 800;
  color: #f3e6c3;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.9);
}

.favorite-entry-count {
  position: relative;
  margin-left: 0;
  padding-left: 14rpx;
  color: #dfd4c1;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.9);
  animation: badgePop 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.favorite-entry-count::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 2rpx;
  height: 18rpx;
  background: linear-gradient(180deg, transparent, rgba(212, 168, 75, 0.6), transparent);
}

@keyframes badgePop {
  0% { transform: translateX(8rpx); opacity: 0; }
  100% { transform: translateX(0); opacity: 1; }
}

