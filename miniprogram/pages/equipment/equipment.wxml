<view class="container flex-col">
  <view class="header-nav">
    <view class="nav-top flex-row align-center justify-between">
      <text class="back-text" bindtap="onBackTap">← 返回</text>
      <text class="class-armor">{{classMeta.armorTypeName}}</text>
    </view>
    <text class="page-title">{{className}}</text>
    <text class="page-subtitle">按专精、属性和部位实时筛选当前可用装备</text>
  </view>

  <view class="filter-section">
    <view class="filter-header flex-row align-center justify-between">
      <view>
        <text class="filter-summary">{{resultCount}} 件结果</text>
        <text class="filter-hint">实时筛选，不需要额外点击查询</text>
      </view>
      <view class="reset-button" bindtap="resetFilters">重置</view>
    </view>

    <view class="filter-row">
      <view class="filter-label">专精</view>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-items">
          <view
            wx:for="{{specs}}"
            wx:key="id"
            class="filter-tag {{selectedSpec === item.id ? 'active' : ''}}"
            bindtap="onSpecTap"
            data-id="{{item.id}}"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="filter-row">
      <view class="filter-label">属性</view>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-items">
          <view
            wx:for="{{stats}}"
            wx:key="type"
            class="filter-tag {{item.selected ? 'active' : ''}}"
            bindtap="onStatTap"
            data-type="{{item.type}}"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="filter-row">
      <view class="filter-label">部位</view>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-items">
          <view
            wx:for="{{slots}}"
            wx:key="type"
            class="filter-slot {{selectedSlot === item.type ? 'active' : ''}}"
            bindtap="onSlotTap"
            data-type="{{item.type}}"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <scroll-view scroll-y class="result-list" enhanced show-scrollbar="{{false}}">
    <block wx:if="{{isLoading}}">
      <view class="empty-state">
        <text class="empty-title">数据加载中</text>
      </view>
    </block>

    <block wx:elif="{{filteredItems.length === 0}}">
      <view class="empty-state">
        <text class="empty-title">{{emptyMessage}}</text>
        <text class="empty-copy" wx:if="{{!hasAnyData}}">当前已经补齐 13 个职业的数据文件结构，武僧为真实样例，其余职业等待抓数脚本生成正式数据。</text>
      </view>
    </block>

    <block wx:else>
      <block wx:for="{{groupedItems}}" wx:key="slotType" wx:for-item="group">
        <view class="slot-group">
          <view class="slot-head flex-row align-center justify-between">
            <view class="slot-title">{{group.slotName}}</view>
            <text class="slot-count">{{group.items.length}} 件</text>
          </view>

          <view
            class="item-card flex-row"
            wx:for="{{group.items}}"
            wx:key="id"
            wx:for-item="equip"
            bindtap="onItemTap"
            data-item="{{equip}}"
          >
            <view class="item-icon-wrap" style="background-image: url('https://wow.zamimg.com/images/wow/icons/large/{{equip.icon}}.jpg');"></view>

            <view class="item-info flex-col justify-center">
              <text class="item-name epic-color">{{equip.name}}</text>

              <view class="item-stats text-muted">
                <text class="stat-text">{{equip.statLine}}</text>
              </view>

              <view class="item-source text-muted">
                <text>{{equip.instanceName}} · {{equip.encounterName}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </block>
  </scroll-view>

  <view class="modal-overlay" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal-content flex-col" catchtap="preventClose">
      <view class="modal-close" bindtap="closeModal">×</view>

      <view class="modal-header flex-row">
        <view class="modal-icon" style="background-image: url('https://wow.zamimg.com/images/wow/icons/large/{{selectedItem.icon}}.jpg');"></view>
        <view class="modal-title-area flex-col justify-center">
          <text class="modal-item-name epic-color">{{selectedItem.name}}</text>
          <text class="modal-item-type">{{selectedItem.sourceDifficulty || '当前赛季掉落'}}</text>
          <text class="modal-item-specs">可用专精：{{selectedItem.specNamesText}}</text>
        </view>
      </view>

      <view class="modal-body">
        <view class="tooltip-line tooltip-level">{{selectedItem.itemLevelText}}</view>
        <view wx:if="{{selectedItem.upgradeTrack}}" class="tooltip-line tooltip-level">
          升级：{{selectedItem.upgradeTrack}}
        </view>
        <view wx:if="{{selectedItem.bindType}}" class="tooltip-line">{{selectedItem.bindType}}</view>
        <view wx:if="{{selectedItem.uniqueText}}" class="tooltip-line">{{selectedItem.uniqueText}}</view>
        <view class="tooltip-line">{{selectedItem.slotName}}</view>

        <view
          wx:for="{{selectedItem.primaryOptions}}"
          wx:key="type"
          class="tooltip-line tooltip-primary"
        >
          +{{item.value}} {{item.name}}
        </view>

        <view wx:if="{{selectedItem.stats.stamina}}" class="tooltip-line">
          耐力 +{{selectedItem.stats.stamina.value}}
        </view>
        <view
          wx:for="{{selectedItem.stats.secondary}}"
          wx:key="type"
          class="tooltip-line"
        >
          {{item.name}} +{{item.value}}
        </view>

        <view wx:if="{{selectedItem.effectText}}" class="tooltip-effect-wrap">
          <text class="tooltip-effect-label">{{selectedItem.effectLabel}}：</text>
          <text class="tooltip-effect-text">{{selectedItem.effectText}}</text>
        </view>

        <view wx:if="{{selectedItem.effectCooldown}}" class="tooltip-line tooltip-effect-cooldown">
          冷却：{{selectedItem.effectCooldown}}
        </view>

        <view wx:if="{{!selectedItem.stats.secondary || selectedItem.stats.secondary.length === 0}}" class="tooltip-line tooltip-muted">
          该装备没有常规双副属性。
        </view>

        <view wx:if="{{selectedItem.vendorPrice}}" class="tooltip-line tooltip-vendor">
          卖价：{{selectedItem.vendorPrice}}
        </view>
      </view>

      <view class="modal-footer">
        <text class="source-meta">{{selectedItem.armorType === 'none' ? '通用装备' : selectedItem.armorTypeName}}</text>
        <text class="source-title">{{selectedItem.instanceName}}</text>
        <text class="source-boss">{{selectedItem.encounterName}}</text>
        <text class="source-id">{{selectedItem.itemIdText}}</text>
      </view>
    </view>
  </view>
</view>
