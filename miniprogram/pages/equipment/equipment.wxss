.equipment-page {
  padding: 18rpx 22rpx 0;
  position: relative;
  background: transparent;
}

.page-bg-glow {
  position: fixed;
  border-radius: 999rpx;
  pointer-events: none;
  filter: blur(80rpx);
  opacity: 0.42;
}

.page-bg-glow-top {
  width: 380rpx;
  height: 380rpx;
  top: -80rpx;
  right: -80rpx;
  background: rgba(121, 59, 165, 0.24);
}

.page-bg-glow-bottom {
  width: 420rpx;
  height: 420rpx;
  left: -160rpx;
  bottom: 120rpx;
  background: rgba(255, 187, 18, 0.08);
}

/* ── top bar ── */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: -18rpx -22rpx -20rpx;
  padding: 16rpx 30rpx 16rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(15, 12, 19, 0.15);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.03);
}

.back-btn {
  width: 72rpx;
  font-size: 56rpx;
  line-height: 1;
  color: #f5ead0;
  flex-shrink: 0;
  font-weight: 500;
}

.top-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.top-emblem {
  width: 46rpx;
  height: 46rpx;
}

.top-title {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color:#ffbb12;
}

.armor-pill {
  min-width: 100rpx;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 99rpx;
  border: 2rpx solid rgba(255, 187, 18, 0.26);
  background: linear-gradient(180deg, rgba(38, 30, 23, 0.9) 0%, rgba(20, 16, 14, 0.9) 100%);
  box-shadow:
    0 6rpx 16rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #ffbb12;
  font-size: 24rpx;
  font-weight: 600;
}

.armor-icon {
  font-size: 22rpx;
  margin-top: -2rpx;
}

.hero-share-btn {
  min-width: 0 !important;
  width: auto !important;
  height: 48rpx !important;
  min-height: 0 !important;
  padding: 0 22rpx !important;
  margin: 0 0 0 16rpx !important;
  border-radius: 99rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15) !important;
  background: rgba(0, 0, 0, 0.5) !important;
  color: #c9c3ba;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  line-height: 48rpx !important;
}

.hero-share-btn::after {
  display: none;
}

/* ── hero panel ── */
.hero-panel {
  position: relative;
  min-height: 220rpx;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  background: #141018;
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.4);
}

.hero-banner {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-shade {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(20, 16, 24, 0.98) 0%, rgba(20, 16, 24, 0.85) 45%, rgba(20, 16, 24, 0) 100%),
    linear-gradient(180deg, rgba(20, 16, 24, 0.8) 0%, rgba(20, 16, 24, 0) 25%);
}

.hero-panel-content {
  position: relative;
  z-index: 1;
  padding:78rpx 34rpx 36rpx;
}

.hero-summary-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.hero-count {
  font-size: 90rpx;
  line-height: 0.85;
  font-weight: 900;
  color: #ffbb12;
  letter-spacing: -2rpx;
}

.hero-count-unit {
  font-size: 28rpx;
  color: #c9c3ba;
  font-weight: 600;
  padding-bottom: 0rpx;
}

.hero-share-btn {
  margin: 0 0 -10rpx 6rpx !important;
  padding: 0 24rpx !important;
  height: 52rpx !important;
  border-radius: 99rpx;
  background: rgba(0, 0, 0, 0.45) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.12) !important;
  color: #ffae00 !important;
  font-size: 24rpx !important;
  font-weight: 500 !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  line-height: normal !important;
}

.hero-share-btn::after {
  display: none;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: #a39c92;
  max-width: 460rpx;
}

/* ── filter panel ── */
.filter-panel {
  margin-top: -8rpx;
  border-radius: 28rpx;
  padding: 18rpx 20rpx 18rpx;
  background:
    linear-gradient(180deg, rgba(19, 18, 25, 0.985) 0%, rgba(17, 16, 23, 0.985) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.09);
  overflow: hidden;
  box-shadow:
    0 18rpx 40rpx rgba(0, 0, 0, 0.35),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
}

.search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 86rpx;
  margin-bottom: 16rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(11, 10, 16, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.03);
  box-shadow: inset 0 2rpx 10rpx rgba(255, 255, 255, 0.02);
}

.search-icon {
  color: #8f8678;
  font-size: 40rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  height: 86rpx;
  font-size: 28rpx;
  color: #efe8da;
}

.search-ph {
  color: #71695d;
}

.filter-row {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
}

.filter-row-last {
  padding-bottom: 8rpx;
}

.filter-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  width: 144rpx;
  flex-shrink: 0;
  height: 60rpx;
}

.filter-symbol {
  width: 34rpx;
  text-align: center;
  font-size: 30rpx;
  color: rgba(255, 187, 18, 0.9);
  font-weight: 700;
}

.filter-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffbb12;
  letter-spacing: 1rpx;
}

.chip-grid {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 12rpx;
}

.chip-scroll-x {
  flex: 1;
  width: 0;
  white-space: nowrap;
}

.chip-scroll-wrap {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 14rpx;
}

.chip,
.instance-chip {
  position: relative;
  min-width: 112rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  background: transparent;
  color: #d0cbc4;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.chip.sm {
  min-width: 70rpx;
}

.chip.on,
.instance-chip.on {
  border-color: #ffbb12;
  background: rgba(255, 187, 18, 0.1);
  color: #ffbb12;
  box-shadow: inset 0 0 12rpx rgba(255, 187, 18, 0.05);
}

.chip.excluded {
  border-color: #e05050;
  background: rgba(224, 80, 80, 0.14);
  color: #e05050;
  text-decoration: line-through;
  text-decoration-thickness: 2rpx;
  box-shadow: inset 0 0 12rpx rgba(224, 80, 80, 0.06);
}

.chip.excluded::after {
  content: '';
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  top: 50%;
  height: 2rpx;
  border-radius: 999rpx;
  background: rgba(224, 80, 80, 0.75);
  transform: rotate(-24deg);
  transform-origin: center;
  pointer-events: none;
}

.instance-chip {
  min-width: 150rpx;
}

.filter-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 12rpx 6rpx 2rpx;
}

.filter-summary-note {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8d8579;
}

.reset-btn {
  flex-shrink: 0;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255, 187, 18, 0.28);
  background: rgba(255, 187, 18, 0.1);
  color: #ffbb12;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── empty / loading ── */
.empty-state {
  margin-top: 24rpx;
  padding: 120rpx 30rpx;
  text-align: center;
  border-radius: 28rpx;
  background: rgba(18, 16, 24, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.empty-text {
  font-size: 28rpx;
  color: #867f73;
}

/* ── group section ── */
.group-section {
  margin-top: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(21, 18, 26, 0.95) 0%, rgba(18, 16, 23, 0.95) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 18rpx 38rpx rgba(0, 0, 0, 0.32),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.03);
}

.group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 14rpx;
}

.group-title-wrap,
.group-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.group-meta {
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
}

.group-badge {
  font-size: 26rpx;
  color: #ffbb12;
}

.group-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffbb12;
}

.group-sub {
  display: block;
  font-size: 20rpx;
  color: #8e8677;
}

.group-count {
  font-size: 22rpx;
  color: #a79e8f;
}

/* ── item card ── */
.item-list {
  padding: 10rpx 14rpx 14rpx;
}

.item-card {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-bottom: 14rpx;
  border-radius: 24rpx;
  background: rgba(31, 27, 37, 0.92);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.03),
    0 12rpx 24rpx rgba(0, 0, 0, 0.22);
}

.item-card:active {
  border-color: rgba(255, 187, 18, 0.28);
  background: rgba(38, 33, 45, 0.96);
}

.item-icon-wrap {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 22rpx;
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.3);
}

.item-icon-img {
  width: 100%;
  height: 100%;
}

.item-icon-letter {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background: rgba(163, 53, 238, 0.14);
  font-size: 38rpx;
  font-weight: 700;
  color: var(--epic);
}

.icon-border {
  position: absolute;
  inset: 0;
  border-radius: 16rpx;
  border: 2rpx solid rgba(194, 68, 255, 0.72);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
  pointer-events: none;
}

.item-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-row-1 {
  margin-bottom: 8rpx;
}

.item-row-2 {
  margin-bottom: 6rpx;
}

.item-row-3 {
  margin-bottom: 0;
}

.item-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.item-quality-badge {
  border: 1rpx solid rgba(255, 187, 18, 0.4);
  border-radius: 6rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
  color: #ffbb12;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-meta-line {
  font-size: 22rpx;
  color: #9e9587;
}

.item-stat-line {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--green, #1eff00);
}

.item-source-wrap {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.item-source-text {
  font-size: 22rpx;
  color: #8d8579;
}

.item-arrow {
  font-size: 26rpx;
  line-height: 1;
  color: #6d665b;
  margin-top: -2rpx;
}

.page-end-pad {
  height: 60rpx;
}

/* ── modal / tooltip ── */
.modal-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.8);
  z-index: 99;
}

.modal-card {
  position: relative;
  width: 660rpx;
  height: 84vh;
  max-height: 84vh;
  border-radius: 40rpx;
  overflow: hidden;
  background: #141018;
  border: 2rpx solid rgba(255, 187, 18, 0.4);
  box-shadow:
    0 16rpx 48rpx rgba(0, 0, 0, 0.6),
    0 0 20rpx rgba(255, 187, 18, 0.1);
  display: flex;
  flex-direction: column;
}

.modal-close {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  z-index: 10;
  width: 52rpx;
  height: 52rpx;
  border-radius: 99rpx;
  border: 2rpx solid rgba(255, 187, 18, 0.5);
  color: #ffbb12;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  padding: 0;
  background: rgba(255, 187, 18, 0.05);
}

/* tooltip header */
.tt-header {
  display: flex;
  padding: 40rpx 40rpx 20rpx;
  gap: 24rpx;
  background: transparent;
}

.tt-icon-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.tt-icon-img {
  width: 100%;
  height: 100%;
}

.tt-icon-letter {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background: rgba(163, 53, 238, 0.15);
  font-size: 46rpx;
  font-weight: 700;
  color: var(--epic);
}

.tt-icon-border {
  position: absolute;
  inset: 0;
  border-radius: 16rpx;
  border: 2rpx solid rgba(163, 53, 238, 0.6);
  pointer-events: none;
}

.tt-title-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.tt-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #c95cff;
}

.tt-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.tt-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.05);
  color: #c4bcd2;
  font-size: 22rpx;
}

/* tooltip body */
.tt-body {
  flex: 1;
  height: 0;
  min-height: 0;
  padding: 10rpx 44rpx 40rpx;
}

.tt-section {
  margin-bottom: 6rpx;
}

.tt-divider {
  height: 2rpx;
  background: rgba(255, 255, 255, 0.06);
  margin: 20rpx 0;
}

.tt-ilvl-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.tt-ilvl {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffbb12;
}

.tt-badge-icon {
  width: 38rpx;
  height: 38rpx;
  border: 2rpx solid #c89f53;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tt-badge-icon::after {
  content: '';
  width: 14rpx;
  height: 14rpx;
  border-radius: 99rpx;
  border: 2rpx solid #c89f53;
}

.tt-line {
  display: block;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #a49e93;
}

.white-line {
  color: #fff;
}

.green-line {
  color: var(--green);
}

.socket-line {
  color: #4da3e8;
}

.strong-line {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  display: block;
}

.stat-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 4rpx;
}

.stat-bullet {
  color: #ffbb12;
  font-size: 20rpx;
  margin-right: 14rpx;
  transform: translateY(-2rpx);
}

.stat-bars {
  margin-top: 18rpx;
}

.stat-bar-item {
  margin-bottom: 16rpx;
}

.green-val-row {
  font-size: 26rpx;
  font-weight: 700;
  color: #1eff00;
  margin-top: 18rpx;
  margin-bottom: 12rpx;
  display: block;
}

.bar-track {
  height: 10rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  margin-bottom: 14rpx;
}

.bar-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, rgba(30, 255, 0, 0.4), rgba(30, 255, 0, 0.9));
}

.tt-extra-block {
  padding: 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 187, 18, 0.03);
  border: 2rpx solid rgba(255, 187, 18, 0.2);
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  margin-top: 24rpx;
}

.tt-extra-icon {
  font-size: 32rpx;
  color: #ceaa6b;
  margin-top: -2rpx;
  opacity: 0.8;
}

.tt-extra-col {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  z-index: 2;
}

.tt-extra-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #dcd3c4;
}

.green-text {
  color: #1eff00;
  font-weight: 500;
}

.gold-text {
  color: #e7c46a;
  font-weight: 500;
}

.dim-text {
  color: rgba(220, 211, 196, 0.72);
}

.tt-extra-watermark {
  position: absolute;
  right: -24rpx;
  bottom: -40rpx;
  font-size: 160rpx;
  color: #ffbb12;
  opacity: 0.05;
  z-index: 1;
}

.tt-footer-wrap {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
  margin-bottom: 32rpx;
}

.tt-bot-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #dcd3c4;
}

.tt-bot-icon {
  color: #cda86a;
  font-size: 26rpx;
}

.tt-bot-dim {
  font-size: 22rpx;
  color: #71695d;
  margin-top: 6rpx;
}

.tt-ornament {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 40rpx;
  margin-bottom: 10rpx;
}

.orn-line {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 187, 18, 0.4), transparent);
}

.orn-dot {
  width: 8rpx;
  height: 8rpx;
  background: #ffbb12;
  transform: rotate(45deg);
}
