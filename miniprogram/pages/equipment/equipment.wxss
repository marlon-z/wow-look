.equipment-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 22rpx 22rpx 0;
}

.top-card {
  padding: 28rpx 26rpx 24rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(145deg, rgba(27, 22, 19, 0.96), rgba(19, 17, 24, 0.96)),
    var(--surface);
  border: 2rpx solid rgba(190, 143, 66, 0.18);
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-link {
  font-size: 24rpx;
  color: var(--theme);
}

.page-title {
  display: block;
  margin-top: 18rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.page-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-soft);
}

.filter-panel {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: var(--surface-strong);
  border: 2rpx solid var(--border);
}

.filter-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-count {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.result-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-soft);
}

.reset-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--theme-soft);
  color: var(--theme);
  font-size: 22rpx;
}

.search-box {
  margin-top: 18rpx;
  padding: 0 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.search-input {
  height: 74rpx;
  font-size: 24rpx;
  color: var(--text-main);
}

.search-placeholder {
  color: var(--text-dim);
}

.filter-block {
  margin-top: 18rpx;
}

.filter-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: var(--text-dim);
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
}

.filter-tag {
  margin-right: 14rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-soft);
  font-size: 24rpx;
}

.filter-tag.compact {
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.filter-tag.active {
  border-color: rgba(190, 143, 66, 0.7);
  background: rgba(190, 143, 66, 0.16);
  color: var(--theme);
}

.result-scroll {
  flex: 1;
  height: 0;
  padding: 20rpx 0 32rpx;
}

.empty-card {
  padding: 80rpx 30rpx;
  border-radius: 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.04);
}

.empty-title {
  font-size: 28rpx;
  color: var(--text-soft);
}

.slot-section {
  margin-bottom: 28rpx;
}

.slot-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  padding: 0 6rpx;
}

.source-head {
  align-items: flex-start;
}

.slot-title {
  font-size: 28rpx;
  color: var(--theme);
}

.slot-count {
  font-size: 22rpx;
  color: var(--text-dim);
}

.source-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-soft);
}

.item-card {
  display: flex;
  align-items: center;
  padding: 18rpx;
  margin-bottom: 14rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.03)),
    var(--surface);
}

.item-icon,
.modal-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 30% 30%, rgba(190, 143, 66, 0.24), rgba(190, 143, 66, 0)),
    rgba(255, 255, 255, 0.04);
  border: 2rpx solid rgba(190, 143, 66, 0.32);
}

.item-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 20rpx;
  margin-right: 18rpx;
  overflow: hidden;
}

.item-icon-text {
  font-size: 36rpx;
  color: var(--theme);
  font-weight: 700;
}

.item-icon-image,
.modal-icon-image {
  width: 100%;
  height: 100%;
}

.item-main {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  font-weight: 700;
}

.item-meta,
.item-stat,
.item-source {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-soft);
}

.modal-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.72);
  z-index: 99;
}

.modal-card {
  position: relative;
  width: 660rpx;
  max-height: 84vh;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(18, 15, 22, 0.98);
  border: 2rpx solid rgba(178, 92, 255, 0.4);
}

.modal-close {
  position: absolute;
  top: 18rpx;
  right: 22rpx;
  z-index: 1;
  font-size: 42rpx;
  color: #fff;
}

.modal-header {
  display: flex;
  padding: 30rpx;
  background: linear-gradient(180deg, rgba(178, 92, 255, 0.16), rgba(178, 92, 255, 0.04));
}

.modal-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 22rpx;
  margin-right: 18rpx;
  overflow: hidden;
}

.modal-icon-text {
  font-size: 40rpx;
  color: var(--theme);
  font-weight: 700;
}

.modal-head-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  flex: 1;
}

.modal-name {
  font-size: 32rpx;
  font-weight: 700;
}

.modal-meta,
.modal-specs {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.5;
}

.modal-body {
  max-height: 52vh;
  padding: 24rpx 30rpx 30rpx;
}

.tooltip-quality-bar {
  height: 4rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(178, 92, 255, 0.1), rgba(178, 92, 255, 1), rgba(178, 92, 255, 0.1));
}

.detail-line,
.raw-line {
  display: block;
  margin-bottom: 12rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #fff;
}

.stat-bar-list {
  margin-bottom: 12rpx;
}

.stat-bar-row {
  margin-bottom: 14rpx;
}

.stat-bar-head {
  margin-bottom: 8rpx;
}

.stat-bar-track {
  height: 10rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.08);
}

.stat-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(67, 209, 124, 0.55), rgba(67, 209, 124, 1));
}

.level-line {
  color: #ffd057;
}

.green-line {
  color: var(--green);
}

.raw-block {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.06);
}

.raw-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: var(--text-dim);
}

.modal-footer {
  padding: 20rpx 30rpx 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.03);
}

.footer-line {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-soft);
}
