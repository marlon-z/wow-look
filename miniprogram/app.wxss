page {
  background:
    radial-gradient(circle at top, rgba(190, 143, 66, 0.2) 0%, rgba(190, 143, 66, 0) 26%),
    linear-gradient(180deg, #120f14 0%, #09090c 100%);
  color: #f3efe8;
  font-family: "PingFang SC", "SF Pro Display", "Helvetica Neue", sans-serif;
  --theme: #be8f42;
  --theme-soft: rgba(190, 143, 66, 0.16);
  --surface: rgba(18, 16, 24, 0.92);
  --surface-strong: rgba(25, 22, 31, 0.96);
  --border: rgba(255, 255, 255, 0.08);
  --text-main: #f5f1eb;
  --text-soft: #b9b0a4;
  --text-dim: #857c72;
  --epic: #b25cff;
  --green: #43d17c;
  box-sizing: border-box;
}

view,
text,
scroll-view {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--border);
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-soft);
  font-size: 22rpx;
}

.epic-text {
  color: var(--epic);
}

.muted {
  color: var(--text-soft);
}
