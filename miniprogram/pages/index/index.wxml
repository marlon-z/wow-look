<page-meta page-style="{{pageStyle}}"></page-meta>
<view class="page-shell index-page">
  <image class="global-site-bg" src="{{cosBase}}/assets/public/bg.png" mode="aspectFill" />
  <view class="announcement-entry" bindtap="openAnnouncement">
    <view class="announcement-entry-icon"></view>
    <text class="announcement-entry-label">公告</text>
    <view wx:if="{{hasUnreadAnnouncement}}" class="announcement-entry-dot"></view>
  </view>
  <view class="favorite-entry" bindtap="openFavorites">
    <view class="favorite-entry-icon icon-star-filled"></view>
    <text class="favorite-entry-label">收藏夹</text>
    <view wx:if="{{favoriteCount}}" class="favorite-entry-count">{{favoriteCount}}</view>
  </view>

  <view class="header-section">
    <image class="logo-img" src="{{cosBase}}/assets/public/logo.png" mode="widthFix" />
  </view>

  <view class="prompt-wrap">
    <text class="prompt-text">请选择你的职业</text>
  </view>

  <view class="class-grid-wrap">
    <view class="class-row">
      <view class="class-cell" wx:for="{{row1}}" wx:key="id" bindtap="onClassTap" data-key="{{item.key}}" data-name="{{item.name}}">
        <image class="class-emblem" src="{{item.emblem}}" mode="aspectFit" />
        <text class="class-label" style="color: {{item.color}};">{{item.shortName}}</text>
      </view>
    </view>

    <view class="class-row">
      <view class="class-cell" wx:for="{{row2}}" wx:key="id" bindtap="onClassTap" data-key="{{item.key}}" data-name="{{item.name}}">
        <image class="class-emblem" src="{{item.emblem}}" mode="aspectFit" />
        <text class="class-label" style="color: {{item.color}};">{{item.shortName}}</text>
      </view>
    </view>

    <view class="class-row">
      <view class="class-cell" wx:for="{{row3}}" wx:key="id" bindtap="onClassTap" data-key="{{item.key}}" data-name="{{item.name}}">
        <image class="class-emblem" src="{{item.emblem}}" mode="aspectFit" />
        <text class="class-label" style="color: {{item.color}};">{{item.shortName}}</text>
      </view>
    </view>
  </view>

  <view class="footer-note">
    <view class="footer-ornament"></view>
    <text>采集数据 · 仅供参考</text>
    <view class="footer-ornament"></view>
  </view>

  <view wx:if="{{showFavorites}}" class="favorite-mask" bindtap="closeFavorites">
    <view class="favorite-panel" catchtap="clearPendingRemoveFavorite">
      <view class="favorite-panel-head favorite-panel-head-stacked">
        <view class="favorite-head-main">
          <view class="favorite-title-wrap">
            <view class="favorite-title-icon icon-star-filled"></view>
            <text class="favorite-title">收藏夹</text>
            <text class="favorite-count">共 {{favoriteCount}} 件</text>
          </view>
          <view class="favorite-close" catchtap="closeFavorites">×</view>
        </view>
        <view wx:if="{{favoriteGroups.length}}" class="favorite-head-actions favorite-action-row">
          <button wx:if="{{favoriteGroups.length}}" class="favorite-share-mini" open-type="share" catchtap="clearPendingRemoveFavorite">
            <text>分享收藏</text>
          </button>
          <view wx:if="{{favoriteGroups.length}}" class="favorite-poster-mini" catchtap="createFavoritePoster">{{isPosterGenerating ? '生成中' : '保存图片'}}</view>
          <view wx:if="{{favoriteGroups.length}}" class="favorite-clear-mini" catchtap="clearFavoriteItems">清空</view>
        </view>
      </view>
      <view class="favorite-divider"></view>

      <block wx:if="{{favoriteGroups.length}}">
        <scroll-view class="favorite-list" scroll-y enhanced show-scrollbar="{{false}}">
          <view wx:for="{{favoriteGroups}}" wx:for-item="group" wx:key="classKey" class="favorite-group">
            <view class="favorite-group-head">
              <text class="favorite-group-title">{{group.className}}</text>
              <text class="favorite-group-count">{{group.count}} 件</text>
            </view>
            <view
              wx:for="{{group.items}}"
              wx:for-item="favorite"
              wx:key="key"
              class="favorite-item"
              catchtap="onFavoriteItemTap"
              data-item-id="{{favorite.itemId}}"
              data-class-key="{{favorite.classKey}}"
              data-class-name="{{favorite.className}}"
            >
              <view class="favorite-icon-wrap">
                <image wx:if="{{favorite.iconAsset}}" class="favorite-icon-img" src="{{favorite.iconAsset}}" mode="aspectFill" />
                <text wx:else class="favorite-icon-letter">{{favorite.iconText}}</text>
                <view class="favorite-icon-border"></view>
              </view>
              <view class="favorite-item-body">
                <view class="favorite-row favorite-row-1">
                  <text class="favorite-name">{{favorite.name}}</text>
                  <view class="favorite-row-actions">
                    <text class="favorite-slot">{{favorite.slotBadgeName || favorite.slotName}}</text>
                    <view class="favorite-remove-btn {{pendingRemoveFavoriteKey === favorite.key ? 'confirm' : ''}}" catchtap="removeFavoriteItem" data-key="{{favorite.key}}">
                      <view class="favorite-remove-icon-sm"></view>
                      <text wx:if="{{pendingRemoveFavoriteKey === favorite.key}}" class="favorite-remove-confirm-text">确认</text>
                    </view>
                  </view>
                </view>
                <view class="favorite-row favorite-row-2">
                  <text class="favorite-stat">{{favorite.statLine}}</text>
                </view>
                <view class="favorite-row favorite-row-3">
                  <text class="favorite-meta-line">{{favorite.className}} · ilvl{{favorite.ilvl}}</text>
                  <view class="favorite-source-wrap">
                    <text class="favorite-source">{{favorite.sourceName}}</text>
                    <text class="favorite-arrow">›</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </scroll-view>
      </block>

      <view wx:else class="favorite-empty">
        <view class="favorite-empty-icon icon-star-outline"></view>
        <text class="favorite-empty-text">还没有收藏装备</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showSharedFavorites}}" class="favorite-mask" bindtap="closeSharedFavorites">
    <view class="favorite-panel shared-favorite-panel" catchtap="preventClose">
      <view class="favorite-panel-head">
        <view class="favorite-title-wrap shared-title-wrap">
          <view class="favorite-title-icon icon-star-filled"></view>
          <view class="shared-title-block">
            <text class="favorite-title">好友分享的装备收藏</text>
            <text wx:if="{{sharedFavoriteSummary}}" class="shared-summary">{{sharedFavoriteSummary}}</text>
          </view>
        </view>
        <view class="favorite-close" catchtap="closeSharedFavorites">×</view>
      </view>
      <view class="favorite-divider"></view>

      <view wx:if="{{isSharedFavoriteLoading}}" class="favorite-empty shared-state">
        <view class="favorite-empty-icon icon-star-outline"></view>
        <text class="favorite-empty-text">正在加载分享内容</text>
      </view>

      <view wx:elif="{{sharedFavoriteError}}" class="favorite-empty shared-state">
        <view class="favorite-empty-icon icon-star-outline"></view>
        <text class="favorite-empty-text">{{sharedFavoriteError}}</text>
      </view>

      <block wx:else>
        <scroll-view class="favorite-list shared-favorite-list" scroll-y enhanced show-scrollbar="{{false}}">
          <view wx:for="{{sharedFavoriteGroups}}" wx:for-item="group" wx:key="classKey" class="favorite-group">
            <view class="favorite-group-head">
              <text class="favorite-group-title">{{group.className}}</text>
              <text class="favorite-group-count">{{group.count}} 件</text>
            </view>
            <view
              wx:for="{{group.items}}"
              wx:for-item="favorite"
              wx:key="key"
              class="favorite-item"
              catchtap="onFavoriteItemTap"
              data-item-id="{{favorite.itemId}}"
              data-class-key="{{favorite.classKey}}"
              data-class-name="{{favorite.className}}"
            >
              <view class="favorite-icon-wrap">
                <image wx:if="{{favorite.iconAsset}}" class="favorite-icon-img" src="{{favorite.iconAsset}}" mode="aspectFill" />
                <text wx:else class="favorite-icon-letter">{{favorite.iconText}}</text>
                <view class="favorite-icon-border"></view>
              </view>
              <view class="favorite-item-body">
                <view class="favorite-row favorite-row-1">
                  <text class="favorite-name">{{favorite.name}}</text>
                  <view class="favorite-row-actions">
                    <text class="favorite-slot">{{favorite.slotBadgeName || favorite.slotName}}</text>
                  </view>
                </view>
                <view class="favorite-row favorite-row-2">
                  <text class="favorite-stat">{{favorite.statLine}}</text>
                </view>
                <view class="favorite-row favorite-row-3">
                  <text class="favorite-meta-line">{{favorite.className}} · ilvl{{favorite.ilvl}}</text>
                  <view class="favorite-source-wrap">
                    <text class="favorite-source">{{favorite.sourceName}}</text>
                    <text class="favorite-arrow">›</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </scroll-view>
        <view class="shared-action-bar">
          <button class="shared-import-btn" bindtap="importSharedFavorites">保存到我的收藏夹</button>
        </view>
      </block>
    </view>
  </view>

  <view wx:if="{{showAnnouncement}}" class="announcement-mask" bindtap="closeAnnouncement">
    <view class="announcement-panel" catchtap="preventClose">
      <view class="announcement-head">
        <view class="announcement-title-wrap">
          <view class="announcement-title-icon"></view>
          <view class="announcement-title-block">
            <text class="announcement-title">{{announcement.title}}</text>
            <text class="announcement-meta">{{announcement.version}} · {{announcement.date}}</text>
          </view>
        </view>
        <view class="favorite-close announcement-close" catchtap="closeAnnouncement">×</view>
      </view>
      <view class="favorite-divider"></view>
      <view class="announcement-body">
        <text class="announcement-summary">{{announcement.summary}}</text>
        <view class="announcement-list">
          <view wx:for="{{announcement.items}}" wx:key="*this" class="announcement-item">
            <view class="announcement-bullet"></view>
            <text class="announcement-item-text">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <equipment-detail
    visible="{{showModal}}"
    item="{{selectedItem}}"
    bind:close="closeModal"
    bind:favorite="onDetailFavoriteTap"
  />

  <canvas
    canvas-id="favoritePosterCanvas"
    class="favorite-poster-canvas"
    style="width: 750px; height: {{posterCanvasHeight}}px;"
  ></canvas>
</view>
