<view class="page-shell equipment-page">
  <image class="global-site-bg" src="https://wowlook-1308073800.cos.ap-guangzhou.myqcloud.com/assets/public/bg.png" mode="aspectFill" />
  <view class="page-bg-glow page-bg-glow-top"></view>
  <view class="page-bg-glow page-bg-glow-bottom"></view>

  <view class="top-bar">
    <text class="back-btn" bindtap="onBackTap">‹</text>
    <view class="top-title-wrap">
      <image class="top-emblem" src="{{classEmblemAsset}}" mode="aspectFit" />
      <text class="top-title">{{className}}</text>
    </view>
    <view class="armor-pill">
      
      <text>{{classMeta.armorTypeName}}</text>
    </view>
  </view>

  <view class="hero-panel">
    <image class="hero-banner" src="{{heroBannerAsset}}" mode="aspectFill" />
    <view class="hero-shade"></view>
    <view class="hero-panel-content">
      <view class="hero-summary-row">
        <text class="hero-count">{{resultCount}}</text>
        <text class="hero-count-unit">件装备</text>
      </view>
      <text class="hero-desc">{{activeFiltersText}}</text>
    </view>
  </view>

  <view class="filter-panel">
    <view class="search-box">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索装备、副本或首领"
        placeholder-class="search-ph"
        value="{{keyword}}"
        bindinput="onKeywordInput"
      />
    </view>

    <view class="filter-row">
      <view class="filter-head">
        <text class="filter-symbol">♚</text>
        <text class="filter-label">专精</text>
      </view>
      <view class="chip-grid">
        <view
          wx:for="{{specs}}"
          wx:key="id"
          class="chip {{selectedSpec === item.id ? 'on' : ''}}"
          bindtap="onSpecTap"
          data-id="{{item.id}}"
        >{{item.name}}</view>
      </view>
    </view>

    <view class="filter-row">
      <view class="filter-head">
        <text class="filter-symbol">✴</text>
        <text class="filter-label">副属性</text>
      </view>
      <view class="chip-grid">
        <view
          wx:for="{{stats}}"
          wx:key="type"
          class="chip {{item.selected ? 'on' : ''}}"
          bindtap="onStatTap"
          data-type="{{item.type}}"
        >{{item.name}}</view>
      </view>
    </view>

    <view class="filter-row">
      <view class="filter-head">
        <text class="filter-symbol">◉</text>
        <text class="filter-label">视图</text>
      </view>
      <view class="chip-grid">
        <view
          wx:for="{{viewModes}}"
          wx:key="type"
          class="chip {{selectedViewMode === item.type ? 'on' : ''}}"
          bindtap="onViewModeTap"
          data-type="{{item.type}}"
        >{{item.name}}</view>
      </view>
    </view>

    <view class="filter-row">
      <view class="filter-head">
        <text class="filter-symbol">▤</text>
        <text class="filter-label">来源</text>
      </view>
      <view class="chip-grid">
        <view
          wx:for="{{sourceTypes}}"
          wx:key="type"
          class="chip {{selectedSourceType === item.type ? 'on' : ''}}"
          bindtap="onSourceTypeTap"
          data-type="{{item.type}}"
        >{{item.name}}</view>
      </view>
    </view>

    <view class="filter-row">
      <view class="filter-head">
        <text class="filter-symbol">♞</text>
        <text class="filter-label">部位</text>
      </view>
      <scroll-view class="chip-scroll-x" scroll-x="true" enhanced show-scrollbar="{{false}}">
        <view class="chip-scroll-wrap">
          <view
            wx:for="{{slots}}"
            wx:key="type"
            class="chip sm {{item.selected ? 'on' : ''}}"
            bindtap="onSlotTap"
            data-type="{{item.type}}"
          >{{item.name}}</view>
        </view>
      </scroll-view>
    </view>

    <view class="filter-row filter-row-last">
      <view class="filter-head">
        <text class="filter-symbol">♜</text>
        <text class="filter-label">副本</text>
      </view>
      <scroll-view class="chip-scroll-x" scroll-x="true" enhanced show-scrollbar="{{false}}">
        <view class="chip-scroll-wrap">
          <block wx:for="{{instanceOptions}}" wx:key="id">
            <view
              wx:if="{{selectedSourceType === 'all' || item.type === selectedSourceType}}"
              class="chip instance-chip {{selectedInstanceId === item.id ? 'on' : ''}}"
              bindtap="onInstanceTap"
              data-id="{{item.id}}"
            >{{item.name}}</view>
          </block>
        </view>
      </scroll-view>
    </view>

    <view class="filter-actions">
      <text class="filter-summary-note">{{activeFiltersText}}</text>
      <text class="reset-btn" catchtap="resetFilters">重置</text>
    </view>
  </view>

  <block wx:if="{{isLoading}}">
    <view class="empty-state">
      <text class="empty-text">加载中…</text>
    </view>
  </block>

  <block wx:elif="{{groupedItems.length === 0}}">
    <view class="empty-state">
      <text class="empty-text">{{emptyMessage}}</text>
    </view>
  </block>

  <block wx:else>
    <block wx:for="{{groupedItems}}" wx:key="slotType">
      <view class="group-section">
        <block wx:if="{{selectedViewMode === 'slot'}}">
          <view class="group-head">
            <view class="group-title-wrap">
              <text class="group-badge">♚</text>
              <text class="group-title">{{item.slotName}}</text>
            </view>
            <text class="group-count">共 {{item.items.length}} 件</text>
          </view>
        </block>
        <block wx:else>
          <view class="group-head">
            <view class="group-meta">
              <text class="group-title">{{item.title}}</text>
              <text class="group-sub">{{item.subtitle}}<block wx:if="{{item.difficultyName}}"> · {{item.difficultyName}}</block></text>
            </view>
            <text class="group-count">共 {{item.items.length}} 件</text>
          </view>
        </block>

        <view class="item-list">
          <view
            wx:for="{{item.items}}"
            wx:key="id"
            wx:for-item="equip"
            class="item-card"
            bindtap="onItemTap"
            data-item-id="{{equip.id}}"
          >
            <view class="item-icon-wrap">
              <image wx:if="{{equip.iconAsset}}" class="item-icon-img" mode="aspectFill" src="{{equip.iconAsset}}" />
              <text wx:else class="item-icon-letter">{{equip.iconText}}</text>
              <view class="icon-border"></view>
            </view>

            <view class="item-body">
              <view class="item-row item-row-1">
                <text class="item-name epic-text">{{equip.name}}</text>
                <text class="item-quality-badge">{{equip.slotName}}</text>
              </view>
              <view class="item-row item-row-2">
                <text class="item-stat-line">{{equip.statLine}}</text>
              </view>
              <view class="item-row item-row-3">
                <text class="item-meta-line">{{equip.rightMeta}} · ilvl{{equip.ilvl}}</text>
                <view class="item-source-wrap">
                  <text class="item-source-text">{{equip.instanceName}}</text>
                  <text class="item-arrow">›</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </block>

  <view class="page-end-pad"></view>

  <!-- modal tooltip -->
  <view wx:if="{{showModal}}" class="modal-mask" bindtap="closeModal">
    <view class="modal-card" catchtap="preventClose">
      <view class="modal-close" bindtap="closeModal">×</view>

      <view class="tt-header">
        <view class="tt-icon-wrap">
          <image wx:if="{{selectedItem.iconAsset}}" class="tt-icon-img" mode="aspectFill" src="{{selectedItem.iconAsset}}" />
          <text wx:else class="tt-icon-letter">{{selectedItem.iconText}}</text>
          <view class="tt-icon-border"></view>
        </view>
        <view class="tt-title-area">
          <text class="tt-name">{{selectedItem.name}}</text>
          <view class="tt-tag-row">
            <text wx:for="{{selectedItem.headerTags}}" wx:key="*this" class="tt-tag">{{item}}</text>
          </view>
        </view>
      </view>

      <scroll-view scroll-y class="tt-body" enhanced show-scrollbar="{{false}}">
        <view class="tt-section">
          <view class="tt-ilvl-row">
            <text class="tt-ilvl">物品等级 {{selectedItem.ilvl}}</text>
            <view class="tt-badge-icon"></view>
          </view>
          <text wx:if="{{selectedItem.upgradeTrack}}" class="tt-line">升级：{{selectedItem.upgradeTrack}}</text>
          <text class="tt-line">{{selectedItem.slotName}}<block wx:if="{{selectedItem.itemSubType}}"> · {{selectedItem.itemSubType}}</block></text>
          <text wx:if="{{selectedItem.tooltipFlags.uniqueEquipped}}" class="tt-line">装备唯一</text>
          <text wx:if="{{selectedItem.tooltipFlags.prismaticSocket}}" class="tt-line socket-line">◇ 棱彩插槽</text>
        </view>

        <view class="tt-divider"></view>

        <view class="tt-section">
          <text wx:if="{{selectedItem.stats.armor}}" class="strong-line">{{selectedItem.stats.armor.value}}点护甲</text>
          
          <block wx:for="{{selectedItem.whiteLines}}" wx:key="*this">
            <text class="tt-line white-line">{{item}}</text>
          </block>

          <block wx:for="{{selectedItem.stats.primaryStats}}" wx:key="type">
            <view class="stat-row">
              <text class="stat-bullet">♦</text>
              <text class="tt-line white-line">+{{item.value}} {{item.name}}</text>
            </view>
          </block>
          
          <view wx:if="{{selectedItem.stats.stamina}}" class="stat-row">
            <text class="stat-bullet">♦</text>
            <text class="tt-line white-line">+{{selectedItem.stats.stamina.value}} {{selectedItem.stats.stamina.name}}</text>
          </view>

          <view wx:if="{{selectedItem.secondaryStats && selectedItem.secondaryStats.length}}" class="stat-bars">
            <view wx:for="{{selectedItem.secondaryStats}}" wx:key="type" class="stat-bar-item">
              <text class="green-val-row">+{{item.value}} {{item.name}}</text>
              <view class="bar-track">
                <view class="bar-fill" style="width: {{item.width}};"></view>
              </view>
            </view>
          </view>
        </view>

        <view wx:if="{{selectedItem.equipEffects.length || selectedItem.useEffects.length || selectedItem.filteredRaw.length}}" class="tt-section">
          <view class="tt-extra-block">
            <text class="tt-extra-icon">◈</text>
            <view class="tt-extra-col">
              <block wx:for="{{selectedItem.equipEffects}}" wx:key="*this">
                <text class="tt-extra-line green-text">装备：{{item}}</text>
              </block>
              <block wx:for="{{selectedItem.useEffects}}" wx:key="*this">
                <text class="tt-extra-line green-text">使用：{{item}}</text>
              </block>
              <block wx:for="{{selectedItem.filteredRaw}}" wx:key="index">
                <text class="tt-extra-line">{{item}}</text>
              </block>
            </view>
            <text class="tt-extra-watermark">✶</text>
          </view>
        </view>

        <view class="tt-divider"></view>
        
        <view class="tt-footer-wrap">
          <view class="tt-bot-item" wx:if="{{selectedItem.specText}}">
            <text class="tt-bot-icon">✦</text>
            <text>拾取专精：{{selectedItem.specText}}</text>
          </view>
          <view class="tt-bot-item" wx:if="{{selectedItem.instanceName}}">
            <text class="tt-bot-icon">⬡</text>
            <text>{{selectedItem.instanceName}}<block wx:if="{{selectedItem.encounterName}}"> · {{selectedItem.encounterName}}</block></text>
          </view>
          <text class="tt-bot-dim">{{selectedItem.source.difficultyName || '史诗'}} · ID {{selectedItem.id}}</text>
        </view>

        <view class="tt-ornament">
          <view class="orn-line"></view>
          <view class="orn-dot"></view>
          <view class="orn-line"></view>
        </view>

      </scroll-view>
    </view>
  </view>
</view>
