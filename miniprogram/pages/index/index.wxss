.container {
  min-height: 100vh;
  padding: 36rpx 30rpx 44rpx;
  background:
    radial-gradient(circle at top, rgba(183, 138, 72, 0.22) 0%, rgba(183, 138, 72, 0) 28%),
    linear-gradient(180deg, #141118 0%, #0b0b0e 100%);
}

.hero-panel {
  padding: 28rpx 28rpx 32rpx;
  margin-top: 16rpx;
  margin-bottom: 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(31, 25, 17, 0.95), rgba(20, 18, 25, 0.95));
  border: 2rpx solid rgba(183, 138, 72, 0.2);
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.24);
}

.eyebrow {
  display: block;
  margin-bottom: 14rpx;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: rgba(229, 229, 229, 0.66);
}

.title {
  display: block;
  font-size: 58rpx;
  font-weight: 800;
  color: var(--theme-color);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 12rpx rgba(183, 138, 72, 0.4);
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 16rpx;
  line-height: 1.6;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.legend-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.05);
  font-size: 22rpx;
  color: var(--text-muted);
}

.section-head {
  margin-bottom: 28rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.section-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.grid-container {
  flex: 1;
}

.class-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx 16rpx;
}

.class-item {
  padding: 20rpx 10rpx 14rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
  border: 2rpx solid rgba(255,255,255,0.05);
  transition: transform 0.2s;
}

.class-item:active {
  transform: scale(0.95);
}

.icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.emoji-icon {
  font-size: 48rpx;
}

.class-name {
  font-size: 24rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.8);
}

.class-armor {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--text-muted);
}

.footer {
  margin-top: 30rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  background: rgba(255,255,255,0.04);
}
